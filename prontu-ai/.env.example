# ── Supabase ──────────────────────────────────
# URL: Settings → API → Project URL
# Key: Settings → API Keys → Publishable Key (sb_publishable_...) ou Anon Key (eyJ...)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_... ou eyJ...

# ── n8n ───────────────────────────────────────
VITE_N8N_BASE_URL=https://n8n-n8n.vk6aah.easypanel.host

# ── Docker ────────────────────────────────────
# Para rodar com Docker:
#   1. Copie este arquivo como .env:  cp .env.example .env
#   2. Preencha os valores acima
#   3. Execute:  docker compose up --build -d
#   4. Acesse:   http://localhost:3000
